# Port the backend listens on. Frontend's VITE_API_BASE_URL should match.
PORT=8080

# MongoDB connection string (Atlas SRV URI). The database name is in the path.
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/rating_system?retryWrites=true&w=majority

# Secret for signing reviewer login tokens (JWT). Use a long random string.
REVIEWER_JWT_SECRET=change-me-to-a-long-random-string

# Admin login credentials and token secret.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=change-me-to-another-long-random-string
